# ============================================================
# Caddyfile — FrankenPHP + Railway (puerto dinámico)
# ============================================================

{
	admin off
	auto_https off
	frankenphp
}

:{$PORT:80} {
	root * /app

	# Servir PHP con FrankenPHP
	php_server

	# Compresión
	encode zstd gzip

	# Logs de error
	log {
		output stderr
		level ERROR
	}
}
